{
  "schemaVersion": 1,
  "id": "allmusic_client",
  "version": "${version}",

  "name": "AllMusic Client",
  "description": "AllMusic Client Mod",
  "authors": [
    "Color_yr"
  ],
  "contact": {
    "homepage": "https://github.com/Coloryr/AllMusic_Client",
    "sources": "https://github.com/Coloryr/AllMusic_Client"
  },

  "license": "GPL-3.0",
  "icon": "assets/allmusic_client/icon.png",

  "environment": "*",
